# === OpenRouter (Primary LLM — free models available) ===
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# === Groq (Fallback LLM — fast inference) ===
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# === Web Search ===
# DuckDuckGo is always available (no key needed). Set Tavily for better results.
WEB_SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=your_tavily_api_key_here

# === Embeddings (optional — falls back to local sentence-transformers) ===
# COHERE_API_KEY=your_cohere_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# === Pinecone (optional — enables persistent vector search) ===
# PINECONE_API_KEY=your_pinecone_api_key_here
# PINECONE_ENVIRONMENT=us-east-1
# PINECONE_INDEX_NAME=deep-research-oracle

# === Optional Provider Keys (for runtime provider switching via UI) ===
# GOOGLE_API_KEY=your_google_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# GROK_API_KEY=your_grok_api_key_here

# === Dynamic Provider (UI-configurable) ===
AI_PROVIDER=openrouter
# AI_API_KEY=
# AI_API_BASE_URL=
# AI_MODEL=

# === Backend ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./oracle.db

# === Frontend ===
# Dev: http://localhost:8000  |  Prod: your Railway/Render backend URL
NEXT_PUBLIC_API_URL=http://localhost:8000
